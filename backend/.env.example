DATABASE_URL="file:./dev.db"
PORT=4000
APP_URL="http://localhost:3000"
# AES-256-GCM master key — used for both bot private keys (existing) and
# KeeperHub API keys (new). 64-char hex (=32 bytes), or any string we hash to
# 32 bytes. Generate: `openssl rand -hex 32`. Required if you connect KeeperHub.
ENCRYPTION_KEY=""

# KeeperHub publishing (optional — only needed if users use the
# "Publish to KeeperHub" feature in /dashboard/builder).
# Default points at hosted KeeperHub; override for self-hosted instances.
KEEPERHUB_API_BASE="https://app.keeperhub.com"

STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PRO_PRICE_ID=""
STRIPE_ENTERPRISE_PRICE_ID=""

