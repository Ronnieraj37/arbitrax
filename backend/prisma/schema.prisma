generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Asset {
  BTC
  ETH
}

enum MarketTimeframe {
  M15
  H1
  H4
  D1
}

model User {
  id        String   @id @default(cuid())
  email     String?  @unique
  name      String?
  image     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bots            Bot[]
  subscription    Subscription?
  backtestResults BacktestResult[]
  trades          Trade[]
}

model Market {
  id        String          @id @default(cuid())
  asset     Asset
  timeframe MarketTimeframe
  slug      String          @unique
  title     String?
  startTs   Int
  endTs     Int

  yesTokenId String?
  noTokenId  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  points   TokenPricePoint[]
  features MarketFeature?

  @@index([asset, timeframe, startTs])
  @@index([asset, timeframe, endTs])
}

model TokenPricePoint {
  id       String @id @default(cuid())
  marketId String
  tokenId  String
  t        Int
  p        Float

  market Market @relation(fields: [marketId], references: [id], onDelete: Cascade)

  @@unique([tokenId, t])
  @@index([marketId, t])
}

model MarketFeature {
  id       String @id @default(cuid())
  marketId String @unique

  minYes Float?
  maxYes Float?
  endYes Float?

  market Market @relation(fields: [marketId], references: [id], onDelete: Cascade)
}

/// A bot in ZLabs is just a pointer to a KeeperHub workflow.
/// All bot logic, triggers, and execution live on KeeperHub. ZLabs only owns
/// the user's identity and the link to their KH workflow.
model Bot {
  id                  String    @id @default(cuid())
  userId              String
  name                String
  status              BotStatus @default(INACTIVE)
  keeperhubWorkflowId String?   @unique
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  trades Trade[]

  @@index([userId])
  @@index([keeperhubWorkflowId])
}

enum BotStatus {
  ACTIVE
  INACTIVE
  PAUSED
  ERROR
}

/// Mirror of trades that originated from a KeeperHub workflow run. Populated
/// only by `POST /api/ingest/trade` (called by the workflow's HTTP-Request node).
model Trade {
  id         String      @id @default(cuid())
  userId     String
  botId      String?
  signal     Signal
  marketSlug String
  tokenId    String
  direction  Direction
  side       TradeSide
  amount     Float
  price      Float
  shares     Float?
  status     TradeStatus @default(PENDING)
  orderId    String?
  pnl        Float?
  pnlPct     Float?
  executedAt DateTime?
  closedAt   DateTime?
  closePrice Float?
  createdAt  DateTime    @default(now())

  keeperhubExecutionId String? @unique
  keeperhubRunId       String?
  paper                Boolean @default(true)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  bot  Bot? @relation(fields: [botId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([botId])
  @@index([marketSlug])
  @@index([status])
  @@index([keeperhubExecutionId])
}

enum Signal {
  BUY
  SELL
}

enum Direction {
  UP
  DOWN
}

enum TradeSide {
  BUY
  SELL
}

enum TradeStatus {
  PENDING
  FILLED
  PARTIALLY_FILLED
  FAILED
  CANCELLED
  CLOSED
}

model Subscription {
  id                   String             @id @default(cuid())
  userId               String             @unique
  plan                 Plan               @default(FREE)
  stripeCustomerId     String?            @unique
  stripeSubscriptionId String?            @unique
  stripePriceId        String?
  status               SubscriptionStatus @default(ACTIVE)
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean            @default(false)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([stripeCustomerId])
}

enum Plan {
  FREE
  PRO
  ENTERPRISE
}

enum SubscriptionStatus {
  ACTIVE
  CANCELED
  PAST_DUE
  INCOMPLETE
}

model BacktestResult {
  id          String   @id @default(cuid())
  userId      String
  name        String   @default("Untitled")
  csvHash     String
  marketType  String
  totalTrades Int      @default(0)
  winRate     Float    @default(0)
  totalPnl    Float    @default(0)
  maxDrawdown Float    @default(0)
  summary     Json
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
