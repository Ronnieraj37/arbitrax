generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  email         String?   @unique
  name          String?
  image         String?
  walletAddress String?   @unique
  emailVerified DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts        Account[]
  sessions        Session[]
  bots            Bot[]
  apiKeys         ApiKey[]
  subscription    Subscription?
  backtestResults BacktestResult[]
  trades          Trade[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Bot {
  id        String    @id @default(cuid())
  userId    String
  name      String
  status    BotStatus @default(INACTIVE)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  // KeeperHub-native fields (post-migration). The KeeperHub workflow IS the bot logic;
  // ZLabs only stores identity + a pointer to the workflow.
  keeperhubWorkflowId String? @unique
  templateSlug        String?

  user    User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  config  BotConfig?
  trades  Trade[]
  apiKeys ApiKey[]

  @@index([userId])
  @@index([keeperhubWorkflowId])
}

enum BotStatus {
  ACTIVE
  INACTIVE
  PAUSED
  ERROR
}

model BotConfig {
  id              String  @id @default(cuid())
  botId           String  @unique
  positionSizeUsd Float   @default(100)
  stopLossPct     Float   @default(10)
  takeProfitPct   Float   @default(20)
  trailingStop    Boolean @default(false)
  maxDailyTrades  Int?
  slippageControl Boolean @default(false)
  maxSlippagePct  Float?
  marketType      String  @default("crypto")

  managedWallet       Boolean @default(false)
  encryptedPrivateKey String? @db.Text
  funderAddress       String?

  bot Bot @relation(fields: [botId], references: [id], onDelete: Cascade)
}

model ApiKey {
  id        String    @id @default(cuid())
  userId    String
  botId     String?
  key       String    @unique
  secret    String
  label     String    @default("default")
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  lastUsed  DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  bot  Bot? @relation(fields: [botId], references: [id], onDelete: SetNull)

  @@index([key])
  @@index([userId])
}

model Trade {
  id         String      @id @default(cuid())
  userId     String
  botId      String?
  signal     Signal
  marketSlug String
  tokenId    String
  direction  Direction
  side       TradeSide
  amount     Float
  price      Float
  shares     Float?
  status     TradeStatus @default(PENDING)
  orderId    String?
  pnl        Float?
  pnlPct     Float?
  executedAt DateTime?
  closedAt   DateTime?
  closePrice Float?
  createdAt  DateTime    @default(now())

  // KeeperHub provenance — every trade now originates from a KH workflow run.
  keeperhubExecutionId String? @unique
  keeperhubRunId       String?
  paper                Boolean @default(true)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  bot  Bot? @relation(fields: [botId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([botId])
  @@index([marketSlug])
  @@index([status])
  @@index([keeperhubExecutionId])
}

enum Signal {
  BUY
  SELL
}

enum Direction {
  UP
  DOWN
}

enum TradeSide {
  BUY
  SELL
}

enum TradeStatus {
  PENDING
  FILLED
  PARTIALLY_FILLED
  FAILED
  CANCELLED
  CLOSED
}

model Subscription {
  id                   String             @id @default(cuid())
  userId               String             @unique
  plan                 Plan               @default(FREE)
  stripeCustomerId     String?            @unique
  stripeSubscriptionId String?            @unique
  stripePriceId        String?
  status               SubscriptionStatus @default(ACTIVE)
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean            @default(false)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([stripeCustomerId])
}

enum Plan {
  FREE
  PRO
  ENTERPRISE
}

enum SubscriptionStatus {
  ACTIVE
  CANCELED
  PAST_DUE
  INCOMPLETE
}

model BacktestResult {
  id          String   @id @default(cuid())
  userId      String
  name        String   @default("Untitled")
  csvHash     String
  marketType  String
  totalTrades Int      @default(0)
  winRate     Float    @default(0)
  totalPnl    Float    @default(0)
  maxDrawdown Float    @default(0)
  summary     Json
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
